# ---------------------------------------------------------------------------
# Ring (required for camera snooze + sensor state)
# ---------------------------------------------------------------------------

# Ring refresh token (required)
# Generate with: npx -p ring-client-api ring-auth-cli
RING_REFRESH_TOKEN=

# Name of the contact sensor on your Ring Alarm (case-insensitive, partial match).
# This sensor's opens trigger the camera snooze.
DOOR_SENSOR_NAME=Front Door

# Name of the Ring camera to snooze (case-insensitive, partial match)
CAMERA_NAME=Front Door

# How long to snooze motion alerts (in minutes)
SNOOZE_MINUTES=30

# Minimum seconds between snooze triggers (prevents rapid-fire if door
# opens/closes repeatedly)
COOLDOWN_SECONDS=60

# ---------------------------------------------------------------------------
# IKEA Dirigera (blind sunset-close gated by Ring sensor state)
# ---------------------------------------------------------------------------

# Dirigera hub IP and access token. To pair, run:
#   npm run pair-dirigera
# It will prompt you to press the action button on the hub. Copy the token
# and IP it prints here.
DIRIGERA_HOST=
DIRIGERA_TOKEN=

# Latitude / longitude used to compute local sunset (decimal degrees).
LATITUDE=
LONGITUDE=

# Path to the blind->sensor mapping file (relative to the project dir).
# See blind-sensor-map.json.example. If the file is missing, all blinds
# close at sunset unconditionally.
BLIND_SENSOR_MAP_FILE=blind-sensor-map.json

# After a guarded blind's sensor closes, wait this many seconds before
# actually closing the blind. Lets you walk back in and shut the door
# without the blind dropping the instant you do.
POST_CLOSE_DELAY_SECONDS=60
